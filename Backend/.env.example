# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (must match your existing realestate DB)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=realestate

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Frontend URL(s) for CORS (comma-separated for multiple sites)
# Example: http://localhost:5173,http://localhost:5174
# In development, localhost / 127.0.0.1 on any port is also allowed if NODE_ENV is not production.
FRONTEND_URL=http://localhost:5173

# Admin Credentials (bcrypt hashed password)
ADMIN_EMAIL=admin@realestate.com
ADMIN_PASSWORD=$2a$10$YourBcryptHashedPasswordHere

# Email Configuration (for OTP/forgot password)
# Gmail: use a 16-char App Password (Google Account → Security → App passwords).
# Paste it with or without spaces — the server strips spaces automatically.
# SMTP_USER must be the same Gmail account that created the App Password.
# SMTP_FROM should normally match SMTP_USER (Gmail rejects random From domains).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Dev only: if SMTP fails (timeout, DNS, or Gmail 535 bad credentials), OTP is still
# accepted and printed in the backend terminal. Use while fixing .env or blocked networks.
# NEVER set to true in production.
# DEV_OTP_TO_CONSOLE=true

# Google OAuth (optional - Phase 2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# AWS S3 (property image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=harshtoletservices-166488239646-ap-south-1-an

# AWS Rekognition (property image moderation + OCR contact scan — uses same AWS_* credentials)
# DetectModerationLabels + DetectText run before images are uploaded to S3.

# Firebase Admin SDK (push notifications) — download service account JSON from Firebase Console
# Option A: path to JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: inline JSON string (single line, escaped)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option C: individual fields
# FIREBASE_PROJECT_ID=harshtoletservices
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@harshtoletservices.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Daily recommendation cron (8:00 AM Asia/Kolkata by default)
DAILY_RECOMMENDATIONS_CRON=0 8 * * *
CRON_TIMEZONE=Asia/Kolkata
ENABLE_DAILY_RECOMMENDATIONS=true
