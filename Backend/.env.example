# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (must match your existing realestate DB)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=realestate

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Frontend URL(s) for CORS (comma-separated for multiple sites)
# Example: http://localhost:5173,http://localhost:5174
# In development, localhost / 127.0.0.1 on any port is also allowed if NODE_ENV is not production.
FRONTEND_URL=http://localhost:5173

# Admin Credentials (bcrypt hashed password)
ADMIN_EMAIL=admin@realestate.com
ADMIN_PASSWORD=$2a$10$YourBcryptHashedPasswordHere

# Email Configuration (for OTP/forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@realestate.com

# Google OAuth (optional - Phase 2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
