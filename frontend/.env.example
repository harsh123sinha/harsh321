VITE_API_BASE_URL=http://127.0.0.1:5000/api

# In dev, property images load as /images/... through Vite’s proxy (see vite.config.js).
# Use the same host here as your running API (127.0.0.1 vs localhost can matter on Windows).
# If images still 404: backend must be running and files must exist under Backend/uploads/.

# Optional override; if unset, WhatsApp uses VITE_CONTACT_PAGE_WHATSAPP or built-in default 9334072476
VITE_WHATSAPP_DEFAULT_NUMBER=

# Property detail — "Contact Us" sidebar (optional; if unset, both default to 9334072476)
VITE_CONTACT_OFFICE_1=9334072476
VITE_CONTACT_OFFICE_2=9334072476
VITE_CONTACT_PAGE_WHATSAPP=9334072476

# Optional: used for listing links inside WhatsApp when window is unavailable (e.g. prerender). Usually leave empty in dev.
VITE_PUBLIC_SITE_URL=
